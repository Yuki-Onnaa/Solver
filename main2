    def solve_manual(self):
        q = self.question_input.get("1.0", tk.END).strip()
        if not q: messagebox.showwarning("Empty", "Please enter a question first."); return
        self.solve_btn.config(state="disabled", text="Solving...")
        self._set_answer("Thinking...")
        def run():
            call_ai(q,
                    on_result=lambda ans: self.after(0, lambda: self._on_manual_result(ans, q)),
                    on_error=lambda err: self.after(0, lambda: self._on_manual_error(err)))
        threading.Thread(target=run, daemon=True).start()

    def _on_manual_result(self, ans, q):
        self._set_answer(ans)
        self.solve_btn.config(state="normal", text="Get Answer")
        log_access(MY_IP, q, ans)

    def _on_manual_error(self, err):
        self._set_answer("Error: " + err)
        self.solve_btn.config(state="normal", text="Get Answer")

    def _set_answer(self, text):
        self.answer_output.config(state="normal")
        self.answer_output.delete("1.0", tk.END)
        self.answer_output.insert(tk.END, text)
        self.answer_output.config(state="disabled")

    def copy_manual_answer(self):
        text = self.answer_output.get("1.0", tk.END).strip()
        if text: self.clipboard_clear(); self.clipboard_append(text)

