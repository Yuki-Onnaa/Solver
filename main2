    def capture_screen(self):
        self.iconify()
        self.after(500, self._do_capture)

    def _do_capture(self):
        self.ss_status.config(text="Capturing screen...")
        self.ss_btn.config(state="disabled", text="Capturing...")
        self.deiconify()
        def run():
            img_b64 = take_screenshot()
            if not img_b64:
                self.after(0, lambda: self._on_ss_error("Could not capture. Run: pip install pillow"))
                return
            self.after(0, lambda: self.ss_status.config(text="Analyzing with AI..."))
            call_ai_with_image(img_b64,
                               on_result=lambda r: self.after(0, lambda: self._on_ss_result(r)),
                               on_error=lambda e: self.after(0, lambda: self._on_ss_error(e)))
        threading.Thread(target=run, daemon=True).start()

    def upload_image(self):
        path = filedialog.askopenfilename(filetypes=[("Image files", "*.png *.jpg *.jpeg *.bmp")])
        if not path: return
        self.ss_status.config(text="Reading image...")
        self.ss_btn.config(state="disabled")
        def run():
            try:
                with open(path, "rb") as f: raw = f.read()
                img_b64 = base64.b64encode(raw).decode("utf-8")
                self.after(0, lambda: self.ss_status.config(text="Analyzing image with AI..."))
                call_ai_with_image(img_b64,
                                   on_result=lambda r: self.after(0, lambda: self._on_ss_result(r)),
                                   on_error=lambda e: self.after(0, lambda: self._on_ss_error(e)))
            except Exception as e:
                self.after(0, lambda: self._on_ss_error(str(e)))
        threading.Thread(target=run, daemon=True).start()

    def _on_ss_result(self, text):
        self.ss_output.config(state="normal"); self.ss_output.delete("1.0", tk.END); self.ss_output.insert(tk.END, text)
        self.ss_status.config(text="Done!")
        self.ss_btn.config(state="normal", text="📸  Capture Screen Now")
        log_access(MY_IP, "[screenshot]", text[:100])

    def _on_ss_error(self, err):
        self.ss_output.config(state="normal"); self.ss_output.delete("1.0", tk.END); self.ss_output.insert(tk.END, "Error: " + err)
        self.ss_status.config(text="Error.")
