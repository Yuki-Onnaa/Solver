    # ── Settings ──────────────────────────────────────────────────
    def _build_settings(self, parent):
        tk.Label(parent, text="Settings", bg="#ffffff", font=("Arial", 11, "bold"), anchor="w").pack(fill="x", padx=20, pady=(16, 4))

        tk.Label(parent, text="Keybinds", bg="#ffffff", font=("Arial", 10, "bold"), anchor="w").pack(fill="x", padx=20, pady=(12, 6))
        tk.Label(parent, text="Click a field and press any key to set the keybind.",
                 bg="#ffffff", font=("Arial", 9), fg="#555", anchor="w").pack(fill="x", padx=20, pady=(0, 12))

        # Screenshot keybind
        row1 = tk.Frame(parent, bg="#ffffff")
        row1.pack(fill="x", padx=20, pady=(0, 10))
        tk.Label(row1, text="Capture Screenshot:", bg="#ffffff", font=("Arial", 10), width=22, anchor="w").pack(side="left")
        self.kb_ss_var = tk.StringVar(value=self.settings.get("keybind_screenshot", "F9"))
        kb_ss_entry = tk.Entry(row1, textvariable=self.kb_ss_var, font=("Arial", 10), relief="solid", bd=1, width=12)
        kb_ss_entry.pack(side="left")
        kb_ss_entry.bind("<FocusIn>", lambda e: kb_ss_entry.delete(0, tk.END))
        kb_ss_entry.bind("<KeyPress>", lambda e: self._capture_key(e, self.kb_ss_var, kb_ss_entry))

        # Solve keybind
        row2 = tk.Frame(parent, bg="#ffffff")
        row2.pack(fill="x", padx=20, pady=(0, 10))
        tk.Label(row2, text="Solve (Manual tab):", bg="#ffffff", font=("Arial", 10), width=22, anchor="w").pack(side="left")
        self.kb_solve_var = tk.StringVar(value=self.settings.get("keybind_solve", "F10"))
        kb_solve_entry = tk.Entry(row2, textvariable=self.kb_solve_var, font=("Arial", 10), relief="solid", bd=1, width=12)
        kb_solve_entry.pack(side="left")
        kb_solve_entry.bind("<FocusIn>", lambda e: kb_solve_entry.delete(0, tk.END))
        kb_solve_entry.bind("<KeyPress>", lambda e: self._capture_key(e, self.kb_solve_var, kb_solve_entry))

        tk.Button(parent, text="Save Settings", command=self._save_settings,
                  bg="#000000", fg="#ffffff", font=("Arial", 11, "bold"),
                  relief="flat", padx=20, pady=8, cursor="hand2").pack(anchor="w", padx=20, pady=(16, 0))

        self.settings_status = tk.Label(parent, text="", bg="#ffffff", font=("Arial", 9), fg="green", anchor="w")
        self.settings_status.pack(fill="x", padx=20, pady=(6, 0))

        # Current keybinds display
        tk.Label(parent, text="Current Active Keybinds", bg="#ffffff", font=("Arial", 10, "bold"), anchor="w").pack(fill="x", padx=20, pady=(24, 6))
        self.kb_display = tk.Label(parent, text=self._keybind_display_text(),
                                    bg="#fafafa", font=("Arial", 10), anchor="w",
                                    relief="solid", bd=1, justify="left", padx=12, pady=10)
        self.kb_display.pack(fill="x", padx=20)

    def _capture_key(self, event, var, entry):
        key = event.keysym
        if key in ("Tab", "Escape"): return
        var.set(key)
        entry.delete(0, tk.END)
        entry.insert(0, key)
        return "break"

    def _save_settings(self):
        self.settings["keybind_screenshot"] = self.kb_ss_var.get().strip() or "F9"
        self.settings["keybind_solve"] = self.kb_solve_var.get().strip() or "F10"
        save_settings(self.settings)
        self._register_keybinds()
        self.kb_display.config(text=self._keybind_display_text())
        self.settings_status.config(text="✓ Settings saved!")
        self.after(2000, lambda: self.settings_status.config(text=""))

    def _keybind_display_text(self):
        ss = self.settings.get("keybind_screenshot", "F9")
        sv = self.settings.get("keybind_solve", "F10")
        return f"  Capture Screenshot:   {ss}\n  Solve (Manual tab):   {sv}"


