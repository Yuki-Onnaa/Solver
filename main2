    def extract_only(self):
        text = self.scan_input.get("1.0", tk.END).strip()
        if not text: messagebox.showwarning("Empty", "Paste some text first."); return
        self._scan_set_output("Detecting questions...")
        self.extract_btn.config(state="disabled")
        def run():
            call_ai(f"Extract all questions from the following text. Return ONLY a JSON array of question strings, nothing else, no markdown:\n\n{text}",
                    system_prompt="You are a question extractor. Return only a JSON array of question strings. No markdown, no explanation.",
                    on_result=lambda r: self.after(0, lambda: self._on_extracted(r)),
                    on_error=lambda e: self.after(0, lambda: self._scan_set_output("Error: " + e)))
        threading.Thread(target=run, daemon=True).start()

    def _on_extracted(self, result):
        self.extract_btn.config(state="normal")
        try: qs = json.loads(result.replace("```json","").replace("```","").strip())
        except: qs = [l.strip() for l in result.split("\n") if l.strip() and ("?" in l or l[0].isdigit())]
        self.extracted_questions = qs
        if not qs: self._scan_set_output("No questions found."); return
        out = f"Found {len(qs)} question(s).\n\n"
        for i, q in enumerate(qs): out += f"Q{i+1}: {q}\n\n"
        self._scan_set_output(out)

    def solve_all(self):
        text = self.scan_input.get("1.0", tk.END).strip()
        if not text: messagebox.showwarning("Empty", "Paste some text first."); return
        self._scan_set_output("Extracting questions...")
        def run():
            call_ai(f"Extract all questions from the following text. Return ONLY a JSON array of question strings, nothing else, no markdown:\n\n{text}",
                    system_prompt="You are a question extractor. Return only a JSON array of question strings. No markdown, no explanation.",
                    on_result=lambda r: self.after(0, lambda: self._solve_list_from_json(r)),
                    on_error=lambda e: self.after(0, lambda: self._scan_set_output("Error: " + e)))
        threading.Thread(target=run, daemon=True).start()

    def _solve_list_from_json(self, result):
        try: qs = json.loads(result.replace("```json","").replace("```","").strip())
        except: qs = [l.strip() for l in result.split("\n") if l.strip() and ("?" in l or l[0].isdigit())]
        if not qs: self._scan_set_output("No questions found."); return
        self._run_solve_list(qs)

    def solve_selected(self):
        if not self.extracted_questions: messagebox.showinfo("Extract First", "Click 'Extract Questions' first."); return
        sel = self._ask_selection()
        if sel: self._run_solve_list(sel)

    def _ask_selection(self):
        win = tk.Toplevel(self)
        win.title("Select Questions"); win.geometry("500x400"); win.configure(bg="#ffffff"); win.grab_set()
        tk.Label(win, text="Select questions to solve:", bg="#ffffff", font=("Arial", 10, "bold")).pack(padx=16, pady=(12,6), anchor="w")
        frame = tk.Frame(win, bg="#ffffff"); frame.pack(fill="both", expand=True, padx=16)
        vars_ = []
        for i, q in enumerate(self.extracted_questions):
            var = tk.BooleanVar(value=True)
            tk.Checkbutton(frame, text=f"Q{i+1}: {q[:80]}{'...' if len(q)>80 else ''}",
                           variable=var, bg="#ffffff", anchor="w", font=("Arial", 9), wraplength=440).pack(fill="x", pady=2)
            vars_.append((var, q))
        selected = []
        def confirm():
            for var, q in vars_:
                if var.get(): selected.append(q)
            win.destroy()
        tk.Button(win, text="Solve Selected", command=confirm, bg="#000000", fg="#ffffff",
                  font=("Arial", 10, "bold"), relief="flat", padx=16, pady=8).pack(pady=12)
        self.wait_window(win)
        return selected

    def _run_solve_list(self, qs):
        self._scan_set_output(f"Solving {len(qs)} question(s)...\n\n")
        self.progress_var.set(0)
        self.solve_all_btn.config(state="disabled"); self.solve_selected_btn.config(state="disabled")
        def run():
            answers = []
            for i, q in enumerate(qs):
                result = {"q": q, "a": None, "err": None}
                done = threading.Event()
                def on_result(ans, r=result, d=done): r["a"] = ans; d.set()
                def on_error(err, r=result, d=done): r["err"] = err; d.set()
                call_ai(q, on_result=on_result, on_error=on_error)
                done.wait()
                answers.append(result)
                self.after(0, lambda p=((i+1)/len(qs)*100): self.progress_var.set(p))
            self.after(0, lambda: self._display_answers(answers))
        threading.Thread(target=run, daemon=True).start()

    def _display_answers(self, answers):
        self.scan_output.config(state="normal"); self.scan_output.delete("1.0", tk.END)
        for i, item in enumerate(answers):
            self.scan_output.insert(tk.END, f"Q{i+1}: {item['q']}\n", "question")
            if item["a"]: self.scan_output.insert(tk.END, f"{item['a']}\n\n"); log_access(MY_IP, item["q"], item["a"])
            else: self.scan_output.insert(tk.END, f"Error: {item['err']}\n\n")
        self.scan_output.tag_config("question", font=("Arial", 11, "bold"))
        self.solve_all_btn.config(state="normal"); self.solve_selected_btn.config(state="normal")

    def _scan_set_output(self, text):
        self.scan_output.config(state="normal"); self.scan_output.delete("1.0", tk.END); self.scan_output.insert(tk.END, text)

    def copy_scan_answers(self):
        text = self.scan_output.get("1.0", tk.END).strip()
        if text: self.clipboard_clear(); self.clipboard_append(text)

